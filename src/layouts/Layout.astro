---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: string;
  canonicalPath?: string;
  ogImage?: string;
}

const {
  title,
  description = 'DAIRIA Law — International French employment law firm. Expert legal counsel for international employers operating in France. Powered by AI.',
  lang = 'en',
  canonicalPath = '',
  ogImage = '/og-default.jpg',
} = Astro.props;

const siteUrl = 'https://dairia-law.com';
const canonicalURL = new URL(canonicalPath, Astro.site);
const ogImageURL = new URL(ogImage, siteUrl).href;

// hreflang mapping
const langMap: Record<string, string> = {
  en: '/',
  de: '/de',
  zh: '/zh',
  ja: '/ja',
  es: '/es',
  it: '/it',
};

// Determine OG locale
const localeMap: Record<string, string> = {
  en: 'en_US',
  de: 'de_DE',
  zh: 'zh_CN',
  ja: 'ja_JP',
  es: 'es_ES',
  it: 'it_IT',
  fr: 'fr_FR',
};
const ogLocale = localeMap[lang] || 'en_US';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="DAIRIA Law" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={ogImageURL} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- hreflang: language alternatives -->
    {Object.entries(langMap).map(([hrefLang, path]) => (
      <link rel="alternate" hreflang={hrefLang} href={`${siteUrl}${path}`} />
    ))}
    <link rel="alternate" hreflang="fr" href="https://dairia-avocats.com" />
    <link rel="alternate" hreflang="x-default" href={siteUrl} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Fonts: system stack (same as dairia-avocats.com) -->
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <Navigation />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
