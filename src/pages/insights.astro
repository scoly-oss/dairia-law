---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const WP_API = 'https://dairia-blog.bl-nk.io/wp-json/wp/v2/posts?_embed=true&per_page=12&categories=1001';

interface WPPost {
  id: number;
  slug: string;
  title: { rendered: string };
  excerpt: { rendered: string };
  date: string;
  _embedded?: {
    'wp:featuredmedia'?: Array<{
      source_url: string;
      alt_text: string;
    }>;
  };
}

let posts: WPPost[] = [];
let fetchError = false;

try {
  const res = await fetch(WP_API);
  if (res.ok) {
    posts = await res.json();
  } else {
    fetchError = true;
  }
} catch (e) {
  fetchError = true;
}

function stripHtml(html: string): string {
  return html.replace(/<[^>]*>/g, '').trim();
}

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const placeholderPosts = [
  { title: 'Understanding French Employment Contracts', excerpt: 'A comprehensive guide to CDI, CDD, and other contract types under French labor law.', date: '2026-03-15' },
  { title: 'Dismissal Procedures in France: What You Need to Know', excerpt: 'Navigating the complex French dismissal process — from prior interview to notification.', date: '2026-03-01' },
  { title: 'Social Security Obligations for Foreign Employers', excerpt: 'Key obligations when hiring employees in France as an international company.', date: '2026-02-15' },
  { title: 'The Macron Scale: Caps on Employment Tribunal Awards', excerpt: 'How the barème Macron affects compensation in unfair dismissal claims.', date: '2026-02-01' },
  { title: 'Remote Work Regulations in France (2026 Update)', excerpt: 'New rules and best practices for managing remote employees under French law.', date: '2026-01-20' },
  { title: 'Collective Bargaining Agreements: A Practical Guide', excerpt: 'How conventions collectives impact your employment obligations in France.', date: '2026-01-05' },
];
---

<Layout
  title="Insights — French Employment Law Updates | DAIRIA Law"
  description="Expert articles and updates on French employment law for international employers. Stay informed on contracts, dismissals, social security, and compliance."
  lang="en"
  canonicalPath="/insights"
>
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-dark via-primary to-primary/80 text-white section-padding overflow-hidden">
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNjAiIGhlaWdodD0iNjAiIHZpZXdCb3g9IjAgMCA2MCA2MCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48ZyBmaWxsPSJub25lIiBvcGFjaXR5PSIuMDUiPjxjaXJjbGUgY3g9IjMwIiBjeT0iMzAiIHI9IjEuNSIgZmlsbD0id2hpdGUiLz48L2c+PC9zdmc+')] opacity-30"></div>
    <div class="container-narrow relative">
      <div class="max-w-3xl">
        <span class="inline-block px-4 py-1.5 bg-accent/20 text-accent font-semibold text-sm rounded-full mb-6">
          Knowledge Hub
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Insights — French Employment Law <span class="text-accent">Updates</span>
        </h1>
        <p class="text-lg md:text-xl text-white/80 max-w-2xl leading-relaxed">
          Expert analysis, practical guides, and the latest developments in French labor law for international employers.
        </p>
      </div>
    </div>
  </section>

  <!-- Articles Grid -->
  <section class="section-padding">
    <div class="container-narrow">
      {posts.length > 0 ? (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => {
            const featuredImage = post._embedded?.['wp:featuredmedia']?.[0];
            return (
              <article class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow group">
                <a href={`/insights/${post.slug}`} class="block">
                  {featuredImage ? (
                    <div class="aspect-[16/9] overflow-hidden">
                      <img
                        src={featuredImage.source_url}
                        alt={featuredImage.alt_text || stripHtml(post.title.rendered)}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        loading="lazy"
                      />
                    </div>
                  ) : (
                    <div class="aspect-[16/9] bg-gradient-to-br from-primary/10 to-accent/10 flex items-center justify-center">
                      <svg class="w-12 h-12 text-primary/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
                    </div>
                  )}
                  <div class="p-6">
                    <time class="text-xs font-medium text-gray-400 uppercase tracking-wider">{formatDate(post.date)}</time>
                    <h2 class="text-lg font-bold text-dark mt-2 mb-3 group-hover:text-primary transition-colors line-clamp-2" set:html={post.title.rendered} />
                    <p class="text-sm text-gray-600 line-clamp-3">{stripHtml(post.excerpt.rendered)}</p>
                    <span class="inline-flex items-center gap-1 text-sm font-semibold text-accent mt-4 group-hover:gap-2 transition-all">
                      Read more
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                    </span>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      ) : (
        <div>
          {fetchError && (
            <div class="text-center mb-12">
              <p class="text-gray-500 text-sm">Articles are being loaded from our content platform. Here are some of our recent topics:</p>
            </div>
          )}
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {placeholderPosts.map((post) => (
              <article class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow group">
                <div class="aspect-[16/9] bg-gradient-to-br from-primary/10 to-accent/10 flex items-center justify-center">
                  <svg class="w-12 h-12 text-primary/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
                </div>
                <div class="p-6">
                  <time class="text-xs font-medium text-gray-400 uppercase tracking-wider">{formatDate(post.date)}</time>
                  <h2 class="text-lg font-bold text-dark mt-2 mb-3 group-hover:text-primary transition-colors">{post.title}</h2>
                  <p class="text-sm text-gray-600">{post.excerpt}</p>
                  <span class="inline-flex items-center gap-1 text-sm font-semibold text-accent mt-4 group-hover:gap-2 transition-all">
                    Coming soon
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                  </span>
                </div>
              </article>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="section-padding bg-gray-50">
    <div class="container-narrow text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-dark mb-4">
        Stay Informed
      </h2>
      <p class="text-gray-600 text-lg mb-8 max-w-2xl mx-auto">
        Get the latest insights on French employment law delivered directly to your inbox.
      </p>
      <a href="/contact" class="btn-primary">
        Subscribe to Updates
      </a>
    </div>
  </section>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
