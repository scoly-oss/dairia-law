---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="DAIRIA AI — AI-Powered French Employment Law Intelligence | DAIRIA Law"
  description="DAIRIA AI delivers instant, sourced answers to French employment law questions in 12+ languages. Built for HR teams and in-house counsel worldwide."
  canonicalPath="/dairia-ai"
>
  <!-- Breadcrumb JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dairia-law.com/" },
      { "@type": "ListItem", "position": 2, "name": "DAIRIA AI", "item": "https://dairia-law.com/dairia-ai" }
    ]
  })} />

  <!-- FAQ JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is DAIRIA AI a replacement for a lawyer?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "DAIRIA AI is designed to complement, not replace, legal counsel. It provides instant, sourced answers in your language to routine French employment law questions, freeing up your team. When you need deeper legal support — contracts, disputes, restructuring — our English-speaking lawyers at DAIRIA Avocats handle your case personally."
        }
      },
      {
        "@type": "Question",
        "name": "How accurate are the answers?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "DAIRIA AI is built and supervised by French employment lawyers. Every answer cites its legal sources -- Code du travail articles, Cour de cassation decisions, and collective agreement provisions -- so you can verify independently. Our legal team continuously reviews and improves the system's accuracy."
        }
      },
      {
        "@type": "Question",
        "name": "Is my data secure and confidential?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. DAIRIA AI runs on AWS infrastructure in Paris, France. All data is encrypted with AES-256 at rest and TLS 1.3 in transit. We are fully GDPR compliant. Your queries and documents are never shared with third parties or used to train models for other clients."
        }
      },
      {
        "@type": "Question",
        "name": "Can DAIRIA AI handle my specific collective agreement?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. DAIRIA AI already covers hundreds of French collective bargaining agreements (conventions collectives). Additionally, with the custom training feature, you can upload your specific company-level agreements, internal policies, and HR procedures so that answers reflect your exact context."
        }
      },
      {
        "@type": "Question",
        "name": "How quickly is new legislation integrated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "New laws, decrees, and significant Cour de cassation decisions are integrated within 48 hours of publication. Our legal team monitors the Journal Officiel and legal databases daily to ensure DAIRIA AI always reflects the current state of French employment law."
        }
      },
      {
        "@type": "Question",
        "name": "What languages does DAIRIA AI support?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "DAIRIA AI supports 12+ languages including English, French, German, Mandarin, Japanese, Spanish, Italian, Arabic, Portuguese, Korean, Hindi, and Russian. You can ask your question in any supported language and receive a fully sourced answer in that same language."
        }
      }
    ]
  })} />

  <!-- Hero -->
  <section class="relative bg-[#1D627A] text-white py-20 lg:py-28 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-10 left-10 w-72 h-72 bg-[#FF6B35] rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-96 h-96 bg-white rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 mb-8">
        <span class="w-2 h-2 bg-[#FF6B35] rounded-full animate-pulse"></span>
        <span class="text-sm font-medium text-white/90">Now available for international teams</span>
      </div>
      <h1 class="font-sans text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
        Ask in Your Language.<br class="hidden md:block" /> Get French Law Answers.
      </h1>
      <p class="text-xl md:text-2xl text-white/80 max-w-3xl mx-auto leading-relaxed mb-10">
        The first AI that answers French employment law questions in German, Chinese, Japanese, Spanish, Italian, English and more. Instant. Sourced. 24/7.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="#pricing"
          class="inline-flex items-center justify-center gap-2 bg-[#FF6B35] hover:bg-[#e55a2a] text-white font-semibold px-8 py-4 rounded-lg transition-colors text-lg"
        >
          Start your free trial
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 border border-white/30 text-white font-semibold px-8 py-4 rounded-lg transition-colors text-lg"
        >
          Book a demo
        </a>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-sans text-3xl md:text-4xl font-bold text-gray-900 mb-4">How It Works</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Get reliable, sourced answers to your French employment law questions in three simple steps.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
        <!-- Step 1 -->
        <div class="text-center">
          <div class="w-16 h-16 bg-[#1D627A] text-white rounded-2xl flex items-center justify-center mx-auto mb-6 text-2xl font-bold">1</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Ask in your language</h3>
          <p class="text-gray-600 leading-relaxed">
            Type your question in German, Chinese, Japanese, Spanish, Italian, English or any other language. DAIRIA AI understands the nuances of French employment law — and speaks your language.
          </p>
        </div>
        <!-- Step 2 -->
        <div class="text-center">
          <div class="w-16 h-16 bg-[#1D627A] text-white rounded-2xl flex items-center justify-center mx-auto mb-6 text-2xl font-bold">2</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">AI analyzes legislation, case law & agreements</h3>
          <p class="text-gray-600 leading-relaxed">
            DAIRIA AI cross-references the Code du travail, Cour de cassation decisions, collective bargaining agreements, and DREETS guidance to build a comprehensive, legally grounded answer.
          </p>
        </div>
        <!-- Step 3 -->
        <div class="text-center">
          <div class="w-16 h-16 bg-[#1D627A] text-white rounded-2xl flex items-center justify-center mx-auto mb-6 text-2xl font-bold">3</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Get a sourced, actionable answer</h3>
          <p class="text-gray-600 leading-relaxed">
            Receive a clear, structured response with precise legal references. Every answer cites its sources so you can verify and share with confidence.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="py-20 lg:py-28 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-sans text-3xl md:text-4xl font-bold text-gray-900 mb-4">Built for Global Teams</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Every feature designed to give international employers instant access to French employment law expertise.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Feature 1: Languages -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 bg-[#1D627A]/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#1D627A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m10.5 21 5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 0 1 6-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 0 1-3.827-5.802" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">12+ Languages</h3>
          <p class="text-sm text-gray-600">English, German, Mandarin, Japanese, Spanish, Italian, French, Arabic, Portuguese, Korean, Hindi, Russian.</p>
        </div>
        <!-- Feature 2: 24/7 -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 bg-[#1D627A]/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#1D627A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">24/7 Availability</h3>
          <p class="text-sm text-gray-600">Get answers any time of day, across any time zone. No waiting for office hours in Paris.</p>
        </div>
        <!-- Feature 3: Legally Sourced -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 bg-[#1D627A]/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#1D627A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Legally Sourced</h3>
          <p class="text-sm text-gray-600">Every answer references the Code du travail, Cass. soc. decisions, and applicable collective agreements.</p>
        </div>
        <!-- Feature 4: Real-time Updates -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 bg-[#1D627A]/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#1D627A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Real-time Updates</h3>
          <p class="text-sm text-gray-600">New legislation, decrees, and case law integrated within 48 hours of publication.</p>
        </div>
        <!-- Feature 5: Secure -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 bg-[#1D627A]/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#1D627A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Confidential & Secure</h3>
          <p class="text-sm text-gray-600">AWS Paris infrastructure. AES-256 encryption, TLS 1.3, fully GDPR compliant. Your data stays in France.</p>
        </div>
        <!-- Feature 6: Custom Training -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 bg-[#1D627A]/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#1D627A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Custom Training</h3>
          <p class="text-sm text-gray-600">Upload your collective agreement and company policies. DAIRIA AI learns your specific context for tailored answers.</p>
        </div>
        <!-- Feature 7: Document Generation -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 bg-[#1D627A]/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#1D627A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Document Generation</h3>
          <p class="text-sm text-gray-600">Generate employment contracts, dismissal letters, legal memos, and other documents in minutes.</p>
        </div>
        <!-- Feature 8: Integration -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 bg-[#1D627A]/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#1D627A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Integration Ready</h3>
          <p class="text-sm text-gray-600">Connect via API, Slack, or Microsoft Teams. Bring French employment law expertise directly into your workflows.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <div class="bg-gradient-to-br from-[#1D627A] to-[#15495b] rounded-2xl p-8 md:p-12 text-white text-center relative overflow-hidden">
          <div class="absolute top-0 right-0 w-64 h-64 bg-[#FF6B35]/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
          <div class="relative">
            <p class="text-white/70 uppercase tracking-wider text-sm font-semibold mb-4">Simple, transparent pricing</p>
            <div class="flex items-baseline justify-center gap-2 mb-2">
              <span class="text-5xl md:text-6xl font-bold">90</span>
              <span class="text-2xl font-medium text-white/80">EUR HT</span>
            </div>
            <p class="text-white/70 text-lg mb-6">per user / month</p>
            <div class="inline-flex items-center gap-2 bg-[#FF6B35] rounded-full px-6 py-2 mb-8">
              <span class="font-semibold">Less than 30 minutes of a lawyer's time</span>
            </div>
            <div class="space-y-3 text-left max-w-md mx-auto mb-10">
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-[#FF6B35] flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span>Unlimited questions</span>
              </div>
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-[#FF6B35] flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span>All 12+ languages included</span>
              </div>
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-[#FF6B35] flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span>Document generation</span>
              </div>
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-[#FF6B35] flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span>Custom training on your company policies</span>
              </div>
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-[#FF6B35] flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span>API, Slack & Teams integrations</span>
              </div>
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-[#FF6B35] flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <span>14-day free trial, no credit card required</span>
              </div>
            </div>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-[#FF6B35] hover:bg-[#e55a2a] text-white font-semibold px-8 py-4 rounded-lg transition-colors text-lg">
                Start your free trial
              </a>
              <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 border border-white/30 text-white font-semibold px-8 py-4 rounded-lg transition-colors text-lg">
                Book a demo
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20 lg:py-28 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-sans text-3xl md:text-4xl font-bold text-gray-900 mb-4">What Our Users Say</h2>
        <p class="text-lg text-gray-600">Trusted by HR teams and in-house counsel across Europe and beyond.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-100">
