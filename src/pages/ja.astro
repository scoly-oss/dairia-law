---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="フランス労働法の専門パートナー | DAIRIA Law"
  description="DAIRIA Lawはフランスに進出する日本企業に、フランス労働法に関する包括的な法的支援を提供します。AI搭載、日本語対応。"
  lang="ja"
  canonicalPath="/ja"
>

  <!-- ヒーローセクション -->
  <section class="relative bg-gradient-to-br from-dark via-primary to-primary text-white section-padding">
    <div class="absolute inset-0 bg-[url('/grid.svg')] opacity-10"></div>
    <div class="container-narrow relative">
      <div class="max-w-3xl">
        <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-4">DAIRIA Law -- パリの法律事務所</p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-sans font-bold leading-tight mb-6">
          フランス労働法の専門パートナー
        </h1>
        <p class="text-lg sm:text-xl text-white/80 leading-relaxed mb-10">
          フランスに子会社を持つ日本企業の皆様へ。DAIRIA Lawは、自動車、電子機器、製造業をはじめとする多くの日本企業のフランス進出を労働法の観点から支援してまいりました。日仏のビジネス文化の違いを熟知した専門家チームが、御社のフランス事業を全面的にサポートいたします。
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#お問い合わせ" class="btn-primary">ご相談の予約</a>
          <a href="#サービス" class="btn-outline">サービス内容</a>
        </div>
      </div>
    </div>
  </section>

  <!-- フランス労働法の特徴 -->
  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-sans font-bold text-dark mb-4">
          日本企業がフランス労働法の専門家を必要とする理由
        </h2>
        <p class="text-lg text-dark/60">
          フランスの労働法は日本の労働法と根本的に異なります。フランスでの事業運営に不可欠な主要な相違点をご紹介します。
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

        <div class="bg-gray-50 rounded-xl p-8 border border-gray-100">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-5">
            <span class="text-primary font-bold text-lg">1</span>
          </div>
          <h3 class="text-xl font-semibold text-dark mb-3">法定週35時間労働制</h3>
          <p class="text-dark/60 leading-relaxed">
            フランスでは法定労働時間が週35時間と定められており、これを超える労働には厳格な規制と割増賃金が適用されます。日本の労働文化とは大きく異なり、残業に対する法的制約は非常に厳しいものとなっています。企業は労働時間の正確な管理が求められます。
          </p>
        </div>

        <div class="bg-gray-50 rounded-xl p-8 border border-gray-100">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-5">
            <span class="text-primary font-bold text-lg">2</span>
          </div>
          <h3 class="text-xl font-semibold text-dark mb-3">無期雇用契約 (CDI) が標準</h3>
          <p class="text-dark/60 leading-relaxed">
            フランスでは無期雇用契約（CDI）が雇用の基本形態です。日本の終身雇用制度とは異なり、CDIは法的に強力な労働者保護を伴い、解雇には正当な理由と厳格な手続きが必要です。有期契約（CDD）の利用は限定的な場合にのみ認められています。
          </p>
        </div>

        <div class="bg-gray-50 rounded-xl p-8 border border-gray-100">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-5">
            <span class="text-primary font-bold text-lg">3</span>
          </div>
          <h3 class="text-xl font-semibold text-dark mb-3">従業員代表機関 (CSE) の設置義務</h3>
          <p class="text-dark/60 leading-relaxed">
            従業員11名以上の企業は、社会経済委員会（CSE: Comité Social et Économique）の設置が法律で義務付けられています。CSEは広範な情報提供権・協議権を有し、企業の重要な意思決定に関与します。日本の労働組合や従業員代表制度とは異なる仕組みです。
          </p>
        </div>

        <div class="bg-gray-50 rounded-xl p-8 border border-gray-100">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-5">
            <span class="text-primary font-bold text-lg">4</span>
          </div>
          <h3 class="text-xl font-semibold text-dark mb-3">年間5週間の有給休暇</h3>
          <p class="text-dark/60 leading-relaxed">
            フランスでは全従業員に年間最低5週間（25営業日）の有給休暇が法的に保障されています。日本の法定有給休暇日数を大幅に上回るだけでなく、RTT（労働時間短縮休暇）などの追加休暇制度もあり、休暇管理は企業にとって重要な課題となります。
          </p>
        </div>

        <div class="bg-gray-50 rounded-xl p-8 border border-gray-100">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-5">
            <span class="text-primary font-bold text-lg">5</span>
          </div>
          <h3 class="text-xl font-semibold text-dark mb-3">厳格な解雇規制</h3>
          <p class="text-dark/60 leading-relaxed">
            フランスでは解雇に「正当かつ重大な事由」（cause réelle et sérieuse）が必要であり、事前面談（entretien préalable）の実施、法定期間の遵守、書面による詳細な理由の通知が求められます。日本の希望退職制度のような柔軟な対応とは異なり、手続き上の瑕疵は多額の損害賠償につながる可能性があります。
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- サービス内容 -->
  <section id="サービス" class="section-padding bg-gray-50">
    <div class="container-narrow">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-sans font-bold text-dark mb-4">
          日本企業向けサービス
        </h2>
        <p class="text-lg text-dark/60">
          フランスにおける御社の事業を、労働法の専門家として包括的に支援いたします。
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-100">
          <div class="w-14 h-14 bg-accent/10 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-dark mb-3">雇用契約と採用支援</h3>
          <p class="text-dark/60 leading-relaxed">
            フランス法に準拠した雇用契約書（CDI・CDD）の作成・レビュー、高額な社会保険料（雇用主負担45%以上）を踏まえた報酬パッケージの設計、試用期間や競業避止義務の適切な設定についてアドバイスいたします。
          </p>
        </div>

        <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-100">
          <div class="w-14 h-14 bg-accent/10 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-dark mb-3">従業員代表機関 (CSE) の運営支援</h3>
          <p class="text-dark/60 leading-relaxed">
            CSEの設置・選挙手続きの支援、労使協議の進め方に関する助言、企業協定（accord d'entreprise）の交渉、従業員代表との関係構築について、日本の労使関係との違いを踏まえてサポートいたします。
          </p>
        </div>

        <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-100">
          <div class="w-14 h-14 bg-accent/10 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.25-8.25-3.286Zm0 13.036h.008v.008H12v-.008Z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-dark mb-3">解雇手続きと労働紛争</h3>
          <p class="text-dark/60 leading-relaxed">
            個別解雇・整理解雇の手続き支援、合意退職（rupture conventionnelle）の交渉、労働裁判所（Conseil de Prud'hommes）での訴訟代理を行います。日本の希望退職パッケージとは大きく異なるフランスの解雇規制に精通した弁護士が対応いたします。
          </p>
        </div>

        <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-100">
          <div class="w-14 h-14 bg-accent/10 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-dark mb-3">駐在員・国際人事サポート</h3>
          <p class="text-dark/60 leading-relaxed">
            日本人駐在員のフランスにおける労働許可・滞在許可の取得支援、現地採用と駐在員の法的地位の違いに関する助言、社会保障協定の活用、帰任時の労働法上の留意点についてアドバイスいたします。
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- DAIRIA AI -->
  <section id="ai" class="section-padding bg-dark text-white">
    <div class="container-narrow">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-4">DAIRIA AI</p>
          <h2 class="text-3xl sm:text-4xl font-sans font-bold mb-6">
            日本語で対応するAI法律アシスタント
          </h2>
          <p class="text-white/70 text-lg leading-relaxed mb-6">
            DAIRIA AIは、フランス労働法に特化した独自開発のAI法律アシスタントです。日本語でネイティブレベルの対応が可能であり、言語の壁を越えてフランス労働法の専門知識にアクセスすることができます。
          </p>
          <ul class="space-y-4 text-white/70">
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-accent flex-shrink-0"></span>
              <span>フランス労働法に関する質問に日本語で即座に回答</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-accent flex-shrink-0"></span>
              <span>最新のフランス労働法典および判例データベースに基づく回答</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-accent flex-shrink-0"></span>
              <span>日仏の労働法制度の違いを踏まえた実務的な説明</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-accent flex-shrink-0"></span>
              <span>欧州内サーバーでの安全なデータ管理（GDPR準拠）</span>
            </li>
          </ul>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-2xl p-8 lg:p-10">
          <div class="text-center">
            <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-2">DAIRIA AI</p>
            <p class="text-4xl font-sans font-bold text-white mb-1">90 EUR <span class="text-lg font-sans font-normal text-white/50">（税別）/月</span></p>
            <p class="text-white/50 text-sm mb-8">ユーザーあたり、契約期間の縛りなし</p>
            <ul class="text-left space-y-3 text-white/70 text-sm mb-8">
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                無制限アクセス
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                ネイティブレベルの日本語対応
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                最新のフランス労働法に対応
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                欧州データセンター（AWS パリリージョン）
              </li>
            </ul>
            <a href="#お問い合わせ" class="btn-primary w-full">今すぐ試す</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 実績データ -->
  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-sans font-bold text-dark mb-4">DAIRIAの実績</h2>
        <p class="text-lg text-dark/60">法律の専門性とAIテクノロジーを融合した、新しい形の法律事務所です。</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
        <div class="bg-gray-50 rounded-xl p-8">
          <p class="text-4xl lg:text-5xl font-sans font-bold text-primary mb-2">15+</p>
          <p class="text-dark/60 font-medium">年のフランス労働法における実務経験</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-8">
          <p class="text-4xl lg:text-5xl font-sans font-bold text-primary mb-2">500+</p>
          <p class="text-dark/60 font-medium">顧問先企業（日系企業を含む多数の国際企業）</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-8">
          <p class="text-4xl lg:text-5xl font-sans font-bold text-accent mb-2">AI</p>
          <p class="text-dark/60 font-medium">日本語対応のAI法律アシスタントを提供する初の事務所</p>
        </div>
      </div>
    </div>
  </section>

  <!-- お問い合わせ -->
  <section id="お問い合わせ" class="section-padding bg-gradient-to-br from-primary to-dark text-white">
    <div class="container-narrow text-center max-w-3xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-sans font-bold mb-6">
        御社のフランス事業についてご相談ください
      </h2>
      <p class="text-white/70 text-lg mb-10 leading-relaxed">
        フランスへの進出計画、現地従業員の採用、労働法上の課題の解決など、どのようなご相談にも対応いたします。日仏のビジネス慣行を熟知した専門チームが、御社のニーズに合わせた最適なソリューションをご提案いたします。初回相談は無料です。
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="mailto:contact@dairia-law.com" class="btn-primary">
          お問い合わせ
        </a>
        <a href="tel:+33100000000" class="btn-outline">
          お電話でのご相談
        </a>
      </div>
      <p class="mt-8 text-white/40 text-sm">24時間以内にご返信いたします。日本語でのご対応が可能です。</p>
    </div>
  </section>

</Layout>
